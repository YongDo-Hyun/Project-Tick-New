" MNV Keymap file for Croatian characters, classical variant, iso-8859-2 encoding
" 
" Maintainer:   Paul B. Mahol <onemda@gmail.com>
" Last Changed: 2007 Oct 14

scriptencoding iso-8859-2

let b:keymap_name = "croatian-iso-8859-2"
" Uncomment line below if you prefer short name
"let b:keymap_name = "hr-iso-8859-2"

loadkeymap
" swap y and z, not important
z	y
Z	Y
y	z
Y	Z

" s<
[	ďż˝
" S<
{	ďż˝
" D/
}	ďż˝
" d/
]	ďż˝
" c<
;	ďż˝
" c'
'	ďż˝
" C<
:	ďż˝
" C'
"	ďż˝
" z<
\	ďż˝
" Z<
|	ďż˝
ďż˝	|
ďż˝	@
ďż˝	\
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	{
ďż˝	}
ďż˝	[
ďż˝	]
@	"
^	&
&	/
*	(
(	)
)	=
_	?
-	'
=	+
+	*
/	-
<	;
>	:
?	_
ďż˝	~
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	^
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	`
ďż˝	ďż˝
ďż˝	ďż˝
ďż˝	ďż˝

