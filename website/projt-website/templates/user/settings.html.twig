{% extends 'base.html.twig' %}

{% block title %}Account Settings{% endblock %}

{% block body %}
<div class="container py-5">
    <div style="margin-bottom: 40px;">
        <h1 style="margin-top: 0;">Account Settings</h1>
        <p>Manage your profile and security preferences. Identity, email, password, and linked accounts are managed through <a href="https://id.projecttick.net/realms/projecttick/account/" target="_blank" rel="noopener">Project Tick SSO</a>.</p>
    </div>

    <div class="grid" style="grid-template-columns: 2fr 1fr;">
        <div>
            <!-- Site Profile (local to this website) -->
            <div class="card" style="margin-bottom: 32px;">
                <h3>Site Profile</h3>
                {{ form_start(formProfile, {'attr': {'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="form-group">
                        <label>Profile Picture</label>
                        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
                            {% if user.avatar %}
                                {% set avatar_url = user.avatar starts with 'http' ? user.avatar : asset('uploads/avatars/' ~ user.avatar) %}
                                <img src="{{ avatar_url }}" width="64" height="64" style="border-radius: 50%; object-fit: cover; border: 1px solid var(--border-color);">
                            {% else %}
                                <img src="https://api.dicebear.com/7.x/identicon/svg?seed={{ user.username ?: user.email }}" width="64" height="64" style="border-radius: 50%; border: 1px solid var(--border-color); background: var(--pt-gray-200);">
                            {% endif %}
                            <div>
                                {{ form_widget(formProfile.avatar, {'attr': {'class': 'form-control', 'style': 'width: auto; display: inline-block;'}}) }}
                                <small class="form-text text-muted" style="display: block;">JPG, PNG or WEBP. Max 2MB.</small>
                                {{ form_errors(formProfile.avatar) }}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        {{ form_label(formProfile.username) }}
                        {{ form_widget(formProfile.username) }}
                        {{ form_help(formProfile.username) }}
                        {{ form_errors(formProfile.username) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(formProfile.biography) }}
                        {{ form_widget(formProfile.biography) }}
                        {{ form_errors(formProfile.biography) }}
                    </div>
                    <div class="grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 0;">
                         <div class="form-group">
                            {{ form_label(formProfile.country) }}
                            {{ form_widget(formProfile.country) }}
                            {{ form_errors(formProfile.country) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(formProfile.timezone) }}
                            {{ form_widget(formProfile.timezone) }}
                            {{ form_errors(formProfile.timezone) }}
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="margin-top: 16px;">Save Profile</button>
                {{ form_end(formProfile) }}
            </div>

            <!-- Keycloak Account Management Links -->
            <div class="card" style="margin-bottom: 32px;">
                <h3>Identity &amp; Security</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 20px;">
                    These settings are managed through Project Tick SSO (Keycloak). You will be redirected to <strong>id.projecttick.net</strong>.
                </p>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <a href="https://id.projecttick.net/realms/projecttick/account/#/personal-info" target="_blank" rel="noopener" class="btn btn-secondary" style="display: flex; align-items: center; gap: 10px; justify-content: flex-start; text-align: left;">
                        <i class="fa-solid fa-user" style="width: 20px; text-align: center;"></i>
                        Personal Info &amp; Email
                    </a>
                    <a href="https://id.projecttick.net/realms/projecttick/account/#/security/signingin" target="_blank" rel="noopener" class="btn btn-secondary" style="display: flex; align-items: center; gap: 10px; justify-content: flex-start; text-align: left;">
                        <i class="fa-solid fa-lock" style="width: 20px; text-align: center;"></i>
                        Password &amp; Two-Factor Auth
                    </a>
                    <a href="https://id.projecttick.net/realms/projecttick/account/#/security/linked-accounts" target="_blank" rel="noopener" class="btn btn-secondary" style="display: flex; align-items: center; gap: 10px; justify-content: flex-start; text-align: left;">
                        <i class="fa-solid fa-link" style="width: 20px; text-align: center;"></i>
                        Linked Accounts (GitHub, GitLab, Microsoft)
                    </a>
                    <a href="https://id.projecttick.net/realms/projecttick/account/#/security/device-activity" target="_blank" rel="noopener" class="btn btn-secondary" style="display: flex; align-items: center; gap: 10px; justify-content: flex-start; text-align: left;">
                        <i class="fa-solid fa-desktop" style="width: 20px; text-align: center;"></i>
                        Active Sessions &amp; Devices
                    </a>
                </div>
            </div>
        </div>

        <div>
            <!-- SSO Status -->
            <div class="card" style="margin-bottom: 32px;">
                <h3>SSO Status</h3>
                {% if user.keycloakId %}
                    <div style="padding: 16px; background: var(--pt-gray-100); border: 1px solid var(--border-color); display: flex; align-items: center; gap: 12px; border-radius: 4px;">
                        <i class="fa-solid fa-circle-check" style="font-size: 24px; color: #2E7D32;"></i>
                        <div>
                            <strong style="color: var(--text-primary);">Project Tick SSO</strong><br>
                            <span style="font-size: 0.9rem; color: var(--text-secondary);">Account linked</span>
                        </div>
                    </div>
                    <a href="https://id.projecttick.net/realms/projecttick/account/" target="_blank" rel="noopener" class="btn btn-secondary" style="width: 100%; margin-top: 16px;">
                        Open Account Console
                    </a>
                {% else %}
                    <a href="{{ path('connect_keycloak_start') }}" class="btn btn-primary" style="width: 100%;">Link Project Tick SSO</a>
                {% endif %}
            </div>

            <!-- Connected Accounts (live from Keycloak) -->
            <div class="card" style="margin-bottom: 32px;">
                <h3>Connected Accounts</h3>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    {% set providers = [
                        {name: 'github', label: 'GitHub', icon: 'fa-brands fa-github', color: '#333'},
                        {name: 'gitlab', label: 'GitLab', icon: 'fa-brands fa-gitlab', color: '#FC6D26'},
                        {name: 'microsoft', label: 'Microsoft', icon: 'fa-brands fa-microsoft', color: '#00A4EF'},
                        {name: 'google', label: 'Google', icon: 'fa-brands fa-google', color: '#4285F4'},
                    ] %}
                    {% for p in providers %}
                        <div style="display: flex; align-items: center; gap: 12px; padding: 10px 12px; border: 1px solid var(--border-color); border-radius: 6px; background: var(--pt-gray-100);">
                            <i class="{{ p.icon }}" style="font-size: 18px; width: 24px; text-align: center; color: {{ p.color }};"></i>
                            <div style="flex: 1;">
                                <strong style="font-size: 0.9rem;">{{ p.label }}</strong>
                                {% if p.name in linkedProviders|keys %}
                                    <div style="font-size: 0.8rem; color: #2E7D32;">
                                        <i class="fa-solid fa-circle-check" style="font-size: 10px;"></i>
                                        {{ linkedProviders[p.name] ?: 'Connected' }}
                                    </div>
                                {% else %}
                                    <div style="font-size: 0.8rem; color: var(--text-secondary);">Not connected</div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                    <a href="https://id.projecttick.net/realms/projecttick/account/#/security/linked-accounts" target="_blank" rel="noopener" class="btn btn-secondary" style="width: 100%; margin-top: 8px; font-size: 0.85rem;">
                        <i class="fa-solid fa-arrow-up-right-from-square" style="margin-right: 6px;"></i>
                        Manage Linked Accounts
                    </a>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card" style="border-color: var(--pt-red); background: rgba(255, 0, 60, 0.05);">
                <h3 style="color: var(--pt-red);">Danger Zone</h3>
                <p style="font-size: 0.9rem; color: var(--text-primary);">Once you delete your account, there is no going back. Please be certain.</p>
                <form action="{{ path('app_user_delete') }}" method="post" onsubmit="return confirm('Are you sure you want to permanently delete your account? This action cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-primary" style="background: var(--pt-red); border-color: var(--pt-red); width: 100%;">Delete Account</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}

