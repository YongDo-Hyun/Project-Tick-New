{% extends 'base.html.twig' %}

{% block title %}Products - Admin{% endblock %}

{% block body %}
<div class="py-5">
    <div class="admin-header reveal-up">
        <h1>Products <span class="admin-breadcrumb">/ Management</span></h1>
        <a href="{{ path('app_admin_products_new') }}" class="btn btn-primary">+ Create New Product</a>
    </div>

    <div class="admin-table-container reveal-up">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Product Details</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th style="text-align: right;">Version</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for product in products %}
                <tr>
                    <td>
                        <div style="font-weight: 700; color: var(--pt-black); font-size: 1.1rem;">{{ product.title }}</div>
                        <div style="display: flex; gap: 8px; margin-top: 4px;">
                            <code style="font-size: 0.75rem; color: var(--pt-gray-500); background: var(--pt-gray-100); padding: 2px 6px;" title="Product Slug">{{ product.slug }}</code>
                            <code style="font-size: 0.75rem; color: var(--pt-blue); background: rgba(0,173,239,0.1); padding: 2px 6px;" title="FTP Folder"><i class="fas fa-folder-open"></i> {{ product.ftpFolderName|default('ProjT-Launcher') }}</code>
                        </div>
                    </td>
                    <td>
                        <span class="status-pill" style="background: var(--pt-gray-100); color: var(--pt-gray-600); border: 1px solid var(--pt-gray-200);">
                            {{ product.productType|default('software')|capitalize }}
                        </span>
                    </td>
                    <td>
                        {% set statusClass = product.productStatus == 'active' ? 'status-active' : (product.productStatus == 'deprecated' ? 'status-warn' : 'status-danger') %}
                        <span class="status-pill {{ statusClass }}">
                            {{ product.productStatus|default('active')|capitalize }}
                        </span>
                    </td>
                    <td style="text-align: right;"><span style="font-family: var(--font-mono); font-weight: 700; color: var(--pt-gray-700);">{{ product.version }}</span></td>
                    <td class="actions">
                        <a href="{{ path('app_admin_products_edit', {'id': product.id}) }}" class="btn btn-secondary" style="padding: 8px 16px; font-size: 0.8rem;">Edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align: center; padding: 80px; color: var(--pt-gray-400);">
                        <i class="fas fa-box-open" style="font-size: 3rem; display: block; margin-bottom: 20px; opacity: 0.3;"></i>
                        No products found in the database.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div class="mt-5 reveal-up">
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary" style="border: none; background: transparent; padding-left: 0;">
            &larr; Return to Overview
        </a>
    </div>
</div>
{% endblock %}
