{% extends 'base.html.twig' %}

{% block title %}Login Successful - Project Tick{% endblock %}

{% block body %}
<div class="container py-5 d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="card p-5 text-center reveal-up shadow-lg" style="max-width: 500px; border-top: 4px solid var(--pt-red);">
        <div class="mb-4">
            <div class="success-icon-wrapper mb-3" style="font-size: 3rem; color: #10b981;">
                <i class="fas fa-check-circle"></i>
            </div>
            <h1 class="h2 mb-2">Welcome Back!</h1>
            <p class="text-muted">You have successfully signed in to Project Tick.</p>
        </div>

        <div class="stagger-reveal">
            <p class="mb-4 reveal-up">You will be redirected to the dashboard in a few seconds.</p>
            
            <div class="d-grid gap-2 reveal-up">
                <a href="{{ path('app_home') }}" class="btn btn-primary">Go to Homepage</a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">Admin Dashboard</a>
                {% else %}
                    <a href="{{ path('app_user_dashboard') }}" class="btn btn-secondary">User Settings</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
    // Optional: Auto redirect after 3 seconds
    setTimeout(function() {
        {% if is_granted('ROLE_ADMIN') %}
            window.location.href = "{{ path('app_admin_dashboard') }}";
        {% else %}
            window.location.href = "{{ path('app_user_dashboard') }}";
        {% endif %}
    }, 3000);
</script>

<style>
.success-icon-wrapper i {
    animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes scaleIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
}
</style>
{% endblock %}
